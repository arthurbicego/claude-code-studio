{
  "name": "claude-code-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Local web UI wrapper around the Claude Code CLI",
  "scripts": {
    "start": "tsx server/index.ts",
    "dev": "./start.sh",
    "typecheck": "tsc -p server/tsconfig.json --noEmit && tsc -b web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "biome check",
    "format": "biome format --write",
    "fix": "biome check --write",
    "postinstall": "node ./server/scripts/fix-pty-helper.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "express-ws": "^5.0.2",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@playwright/test": "1.59.1",
    "@types/express": "5.0.6",
    "@types/express-ws": "3.0.6",
    "@types/node": "25.6.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  }
}
